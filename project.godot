; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Sirius VR"
run/main_scene="uid://cvuly6s3nweo0"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://citbkjrcs3rig"

[autoload]

XRToolsUserSettings="*uid://bqgb8i74tm0t"
XRToolsRumbleManager="*uid://by853dk86g1qw"
ControlPanel="*uid://ciwq32853yxn1"
PlayerManager="*uid://dyff4g8wy7535"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/initial_position_type=3
window/subwindows/embed_subwindows=false
window/per_pixel_transparency/allowed=true

[editor_plugins]

enabled=PackedStringArray("res://addons/godot-xr-tools/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://android/": "gray",
"res://assets/": "green",
"res://scenes/": "red",
"res://scenes/levels/": "yellow",
"res://scenes/levels/niveaux_enfants/": "blue",
"res://scripts/": "purple",
"res://scripts/autoloads/": "purple"
}

[global_group]

